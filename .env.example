# Copy this file to ".env" (same folder) and fill in your real key.
# Never commit the real ".env" file to git — it's already listed in .gitignore.

ANTHROPIC_API_KEY=your-

# Neon Postgres connection string (Dashboard -> your project -> Connection
# Details -> "Connection string", the one that starts postgres://). Optional:
# if this is left blank, the app falls back to the local SQLite file
# (data/app.db) automatically — see core/db.py.
DATABASE_URL=

# Signs the per-browser session cookie (app.storage.user — login + tenant
# selection). REQUIRED for any real deployment: set a long random value. If
# unset the app uses an obvious dev-only default (see app_nicegui.ui.run).
IRCONNECT_STORAGE_SECRET=

# ── Auth bootstrap (see core/auth.py) ──────────────────────────────────────
# First Praxis Point staff (admin) login, seeded ONLY on first boot when no
# staff user exists yet. It is forced to change its password on first sign-in,
# so treat this as a one-time bootstrap credential and rotate it immediately.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Default password stamped onto every seeded client_user login (transcript /
# roster participants + the per-client "praxispointclient" default). Every one
# is forced to change it on first sign-in. Rotate the value here before seeding
# a new tenant; fallback if unset is "PraxisPoint!Change1".
DEFAULT_USER_PASSWORD=
